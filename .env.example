# ================================================
# .env.local - Copy file นี้แล้วใส่ค่าจริง
# ================================================

# ---- Facebook Developer App ----
# สร้างที่: https://developers.facebook.com
FACEBOOK_CLIENT_ID=your_facebook_app_id_here
FACEBOOK_CLIENT_SECRET=your_facebook_app_secret_here

# ---- Supabase ----
# สร้างที่: https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ---- Anthropic Claude AI ----
# สร้างที่: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# ---- NextAuth ----
NEXTAUTH_URL=http://localhost:3000
# Production: NEXTAUTH_URL=https://your-app.vercel.app

# Generate ด้วย: openssl rand -base64 32
NEXTAUTH_SECRET=your_random_32_char_secret_here

# ---- Vercel Cron Secret ----
# Generate ด้วย: openssl rand -hex 16
CRON_SECRET=your_cron_secret_here

# ---- Facebook Messenger Webhook (สำหรับฟีเจอร์ตอบแชท) ----
# verify token เป็น string สุ่มที่ตั้งเอง — ต้องตรงกับใน FB App → Webhooks → Verify Token
# Generate ด้วย: openssl rand -hex 16
FB_WEBHOOK_VERIFY_TOKEN=your_random_verify_token_here
